.DS_Store
*.tar.gz
*.bak
*~
# dotmesh no versiona ningún artefacto de IA: ignora todo .ai/ (.ai/tasks incluido).
# La política "cada proyecto decide sobre .ai/tasks/" aplica a repos destino vía /setup.
.ai/

# Stow may produce this when conflicts occur
*.orig

# Estado runtime de las CLI: lo que el plegado de stow deposita dentro del worktree
# cuando los dirs destino no existen en una instalación nueva. Estos ficheros contienen
# tokens, historial y caché; no deben versionarse nunca.
claude/.claude/.credentials.json
claude/.claude/settings.local.json
claude/.claude/history*
claude/.claude/sessions/
claude/.claude/projects/
claude/.claude/todos/
claude/.claude/shell-snapshots/
claude/.claude/statsig/
codex/.codex/auth.json
codex/.codex/history*
codex/.codex/sessions/
codex/.codex/log/
opencode/.config/opencode/auth.json
