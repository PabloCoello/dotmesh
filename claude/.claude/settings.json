{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "outputStyle": "maker",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-git.sh"
          },
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/bridge-approver/pretooluse-approve.sh\"; [ -x \"$f\" ] && exec \"$f\"; exit 0",
            "timeout": 310
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/remind-review-gate.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/remind-load-skills.sh"
          },
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/bridge-approver/pretooluse-approve.sh\"; [ -x \"$f\" ] && exec \"$f\"; exit 0",
            "timeout": 310
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/bridge-approver/pretooluse-ask.sh\"; [ -x \"$f\" ] && exec \"$f\"; exit 0",
            "timeout": 310
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/bridge-approver/userpromptsubmit-watch.sh\"; [ -x \"$f\" ] && exec \"$f\"; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/bridge-approver/stop-reprompt.sh\"; [ -x \"$f\" ] && exec \"$f\"; exit 0",
            "timeout": 310
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/bridge-approver/notification-notify.sh\"; [ -x \"$f\" ] && exec \"$f\" idle_prompt; exit 0"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/bridge-approver/notification-notify.sh\"; [ -x \"$f\" ] && exec \"$f\" permission_prompt; exit 0"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/bridge-approver/stopfailure-notify.sh\"; [ -x \"$f\" ] && exec \"$f\"; exit 0"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/herdr-agent-state.sh session",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/remind-herdr-skill.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enableWorkflows": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "miro@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "miro-ai": {
      "source": {
        "source": "github",
        "repo": "miroapp/miro-ai"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "remoteControlAtStartup": true
}
