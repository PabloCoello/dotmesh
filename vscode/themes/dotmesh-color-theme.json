{
  "$schema": "vscode://schemas/color-theme",
  "name": "dotmesh",
  "type": "dark",
  "colors": {
    "focusBorder": "#5c5c5c",
    "foreground": "#cecece",
    "selection.background": "#6CB6B033",
    "scrollbar.shadow": "#00000000",
    "editor.background": "#121212",
    "editor.foreground": "#cecece",
    "editorCursor.foreground": "#6CB6B0",
    "editor.lineHighlightBackground": "#181818",
    "editor.lineHighlightBorder": "#00000000",
    "editor.selectionBackground": "#6CB6B033",
    "editor.inactiveSelectionBackground": "#6CB6B01F",
    "editor.selectionHighlightBackground": "#6CB6B026",
    "editor.wordHighlightBackground": "#6CB6B026",
    "editor.wordHighlightStrongBackground": "#6CB6B033",
    "editor.findMatchBackground": "#E3C58A66",
    "editor.findMatchHighlightBackground": "#E3C58A33",
    "editorLineNumber.foreground": "#474747",
    "editorLineNumber.activeForeground": "#9e9e9e",
    "editorIndentGuide.background1": "#00000000",
    "editorIndentGuide.activeBackground1": "#00000000",
    "tree.indentGuidesStroke": "#00000000",
    "tree.inactiveIndentGuidesStroke": "#00000000",
    "editorWhitespace.foreground": "#2e2e2e",
    "editorRuler.foreground": "#202020",
    "editorBracketMatch.background": "#6CB6B026",
    "editorBracketMatch.border": "#6CB6B0",
    "editorError.foreground": "#E59A9A",
    "editorWarning.foreground": "#FFAA7A",
    "editorInfo.foreground": "#8FB4E3",
    "editorGutter.addedBackground": "#A8CBA0",
    "editorGutter.modifiedBackground": "#E3C58A",
    "editorGutter.deletedBackground": "#E59A9A",
    "editorWidget.background": "#181818",
    "editorWidget.border": "#2a2a2a",
    "editorHoverWidget.background": "#181818",
    "editorHoverWidget.border": "#2a2a2a",
    "editorSuggestWidget.background": "#181818",
    "editorSuggestWidget.border": "#2a2a2a",
    "editorSuggestWidget.selectedBackground": "#202020",
    "editorSuggestWidget.highlightForeground": "#cecece",
    "sideBar.background": "#181818",
    "sideBar.foreground": "#9e9e9e",
    "sideBar.border": "#00000000",
    "sideBarTitle.foreground": "#6e6e6e",
    "sideBarSectionHeader.background": "#181818",
    "sideBarSectionHeader.foreground": "#9e9e9e",
    "sideBarSectionHeader.border": "#00000000",
    "activityBar.background": "#181818",
    "activityBar.foreground": "#cecece",
    "activityBar.inactiveForeground": "#6e6e6e",
    "activityBar.border": "#00000000",
    "activityBarBadge.background": "#6CB6B0",
    "activityBarBadge.foreground": "#121212",
    "statusBar.background": "#121212",
    "statusBar.foreground": "#9e9e9e",
    "statusBar.border": "#00000000",
    "statusBar.noFolderBackground": "#121212",
    "statusBar.debuggingBackground": "#121212",
    "statusBar.debuggingForeground": "#FFAA7A",
    "statusBarItem.remoteBackground": "#202020",
    "statusBarItem.remoteForeground": "#cecece",
    "statusBarItem.hoverBackground": "#202020",
    "statusBarItem.errorBackground": "#00000000",
    "statusBarItem.errorForeground": "#E59A9A",
    "statusBarItem.warningBackground": "#00000000",
    "statusBarItem.warningForeground": "#FFAA7A",
    "problemsErrorIcon.foreground": "#E59A9A",
    "problemsWarningIcon.foreground": "#FFAA7A",
    "problemsInfoIcon.foreground": "#8FB4E3",
    "titleBar.activeBackground": "#181818",
    "titleBar.activeForeground": "#9e9e9e",
    "titleBar.inactiveBackground": "#181818",
    "titleBar.inactiveForeground": "#6e6e6e",
    "titleBar.border": "#00000000",
    "panel.background": "#121212",
    "panel.border": "#00000000",
    "panelTitle.activeForeground": "#cecece",
    "panelTitle.inactiveForeground": "#6e6e6e",
    "panelTitle.activeBorder": "#cecece",
    "tab.activeBackground": "#121212",
    "tab.inactiveBackground": "#181818",
    "tab.activeForeground": "#cecece",
    "tab.inactiveForeground": "#6e6e6e",
    "tab.border": "#00000000",
    "tab.activeBorder": "#00000000",
    "tab.activeBorderTop": "#00000000",
    "tab.hoverBackground": "#202020",
    "editorGroupHeader.tabsBackground": "#181818",
    "editorGroupHeader.tabsBorder": "#00000000",
    "editorGroupHeader.noTabsBackground": "#181818",
    "editorGroup.border": "#00000000",
    "input.background": "#121212",
    "input.foreground": "#cecece",
    "input.placeholderForeground": "#6e6e6e",
    "input.border": "#2a2a2a",
    "inputOption.activeBorder": "#5c5c5c",
    "inputValidation.errorBackground": "#E59A9A22",
    "inputValidation.errorBorder": "#E59A9A",
    "dropdown.background": "#121212",
    "dropdown.foreground": "#cecece",
    "dropdown.border": "#2a2a2a",
    "list.hoverBackground": "#202020",
    "list.activeSelectionBackground": "#202020",
    "list.activeSelectionForeground": "#cecece",
    "list.inactiveSelectionBackground": "#181818",
    "list.inactiveSelectionForeground": "#cecece",
    "list.highlightForeground": "#cecece",
    "list.focusBackground": "#202020",
    "badge.background": "#6CB6B0",
    "badge.foreground": "#121212",
    "button.background": "#6CB6B0",
    "button.foreground": "#121212",
    "button.hoverBackground": "#84C4BF",
    "button.secondaryBackground": "#202020",
    "button.secondaryForeground": "#cecece",
    "progressBar.background": "#6CB6B0",
    "breadcrumb.foreground": "#6e6e6e",
    "breadcrumb.focusForeground": "#cecece",
    "breadcrumb.activeSelectionForeground": "#cecece",
    "breadcrumbPicker.background": "#181818",
    "menu.background": "#181818",
    "menu.foreground": "#cecece",
    "menu.selectionBackground": "#202020",
    "menu.selectionForeground": "#cecece",
    "menu.border": "#2a2a2a",
    "scrollbarSlider.background": "#5c5c5c44",
    "scrollbarSlider.hoverBackground": "#5c5c5c66",
    "scrollbarSlider.activeBackground": "#5c5c5c99",
    "minimap.selectionHighlight": "#6CB6B055",
    "diffEditor.insertedTextBackground": "#A8CBA01F",
    "diffEditor.removedTextBackground": "#E59A9A1F",
    "diffEditor.insertedLineBackground": "#A8CBA014",
    "diffEditor.removedLineBackground": "#E59A9A14",
    "gitDecoration.addedResourceForeground": "#A8CBA0",
    "gitDecoration.modifiedResourceForeground": "#E3C58A",
    "gitDecoration.deletedResourceForeground": "#E59A9A",
    "gitDecoration.untrackedResourceForeground": "#6CB6B0",
    "gitDecoration.ignoredResourceForeground": "#5c5c5c",
    "gitDecoration.conflictingResourceForeground": "#CBAACB",
    "terminal.background": "#121212",
    "terminal.foreground": "#cecece",
    "terminalCursor.foreground": "#6CB6B0",
    "terminal.ansiBlack": "#2a2a2a",
    "terminal.ansiRed": "#E59A9A",
    "terminal.ansiGreen": "#A8CBA0",
    "terminal.ansiYellow": "#E3C58A",
    "terminal.ansiBlue": "#8FB4E3",
    "terminal.ansiMagenta": "#CBAACB",
    "terminal.ansiCyan": "#6CB6B0",
    "terminal.ansiWhite": "#c6c6c6",
    "terminal.ansiBrightBlack": "#5c5c5c",
    "terminal.ansiBrightRed": "#EAA9A9",
    "terminal.ansiBrightGreen": "#B9D6B2",
    "terminal.ansiBrightYellow": "#ECD2A3",
    "terminal.ansiBrightBlue": "#A8C6EA",
    "terminal.ansiBrightMagenta": "#D8BFD8",
    "terminal.ansiBrightCyan": "#84C4BF",
    "terminal.ansiBrightWhite": "#F0F1F3"
  },
  "semanticHighlighting": false,
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6e6e6e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables and basic text",
      "scope": [
        "variable",
        "meta.object-literal.key",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#cecece"
      }
    },
    {
      "name": "Keywords and control flow",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#CBAACB"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#8FB4E3"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#A8CBA0"
      }
    },
    {
      "name": "Numbers and booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#FFAA7A"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#E3C58A"
      }
    },
    {
      "name": "Error highlighting",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#E59A9A",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Decorators and annotations",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#CBAACB"
      }
    },
    {
      "name": "Self / language special variable",
      "scope": [
        "variable.language.special.self.python",
        "variable.language.this",
        "variable.language"
      ],
      "settings": {
        "foreground": "#6CB6B0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python: Classes and types",
      "scope": [
        "entity.name.type.class.python",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#E3C58A"
      }
    },
    {
      "name": "Python: Function definitions",
      "scope": [
        "entity.name.function.python"
      ],
      "settings": {
        "foreground": "#8FB4E3"
      }
    },
    {
      "name": "Python: Built-in functions",
      "scope": [
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#8FB4E3"
      }
    },
    {
      "name": "Python: Magic methods",
      "scope": [
        "support.function.magic.python"
      ],
      "settings": {
        "foreground": "#6CB6B0"
      }
    },
    {
      "name": "Python: Keywords",
      "scope": [
        "keyword.control.import.python",
        "keyword.control.flow.python",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#CBAACB"
      }
    },
    {
      "name": "Python: Docstrings",
      "scope": [
        "string.quoted.docstring.multi.python"
      ],
      "settings": {
        "foreground": "#6e6e6e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python: Module / namespace names",
      "scope": [
        "entity.name.namespace.python"
      ],
      "settings": {
        "foreground": "#E3C58A"
      }
    },
    {
      "name": "R: Function names",
      "scope": [
        "entity.name.function.r",
        "support.function.r"
      ],
      "settings": {
        "foreground": "#8FB4E3"
      }
    },
    {
      "name": "R: Assignment and pipe operators",
      "scope": [
        "keyword.operator.assignment.r",
        "keyword.operator.pipe.r"
      ],
      "settings": {
        "foreground": "#CBAACB"
      }
    },
    {
      "name": "R: Variables and data frame columns",
      "scope": [
        "variable.other.r",
        "variable.other.member.r"
      ],
      "settings": {
        "foreground": "#6CB6B0"
      }
    },
    {
      "name": "R: Package names and namespaces",
      "scope": [
        "entity.name.namespace.r",
        "support.class.r"
      ],
      "settings": {
        "foreground": "#E3C58A"
      }
    },
    {
      "name": "R: Strings",
      "scope": [
        "string.quoted.double.r",
        "string.quoted.single.r"
      ],
      "settings": {
        "foreground": "#A8CBA0"
      }
    },
    {
      "name": "Markdown: Headings",
      "scope": [
        "markup.heading.markdown",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#8FB4E3",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown: Bold text",
      "scope": [
        "markup.bold.markdown"
      ],
      "settings": {
        "foreground": "#FFAA7A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown: Italic text",
      "scope": [
        "markup.italic.markdown"
      ],
      "settings": {
        "foreground": "#6CB6B0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown: Links",
      "scope": [
        "markup.underline.link.markdown",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#6CB6B0",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown: Inline code",
      "scope": [
        "markup.inline.raw.markdown"
      ],
      "settings": {
        "foreground": "#A8CBA0"
      }
    },
    {
      "name": "YAML: Keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#8FB4E3"
      }
    },
    {
      "name": "YAML: Values",
      "scope": [
        "string.unquoted.plain.out.yaml",
        "string.quoted.double.yaml",
        "string.quoted.single.yaml"
      ],
      "settings": {
        "foreground": "#A8CBA0"
      }
    },
    {
      "name": "JSON: Property names",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#8FB4E3"
      }
    },
    {
      "name": "JSON: Values",
      "scope": [
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#A8CBA0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.relational"
      ],
      "settings": {
        "foreground": "#9e9e9e"
      }
    },
    {
      "name": "Punctuation and brackets",
      "scope": [
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end",
        "punctuation.separator.comma",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#9e9e9e"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape",
        "punctuation.definition.raw.markdown"
      ],
      "settings": {
        "foreground": "#6CB6B0"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#E59A9A"
      }
    },
    {
      "name": "HTML/XML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E3C58A"
      }
    }
  ]
}
