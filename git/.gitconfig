[user]
	name = PabloCoello
	email = pcoello91@gmail.com

[core]
	editor = nvim
	pager = delta
	autocrlf = input

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	default = simple
	autoSetupRemote = true

[fetch]
	prune = true

[diff]
	colorMoved = default

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	light = false
	side-by-side = true
	line-numbers = true
	syntax-theme = Pandora
	
	# dotmesh — Paper · Ink · Syntax (sage = adición, rose = eliminación)
	minus-style = "syntax #E59A9A"
	minus-emph-style = "syntax #EAA9A9"
	plus-style = "syntax #A8CBA0"
	plus-emph-style = "syntax #B9D6B2"
	hunk-header-style = "file line-number syntax #8FB4E3"

	# Line numbers
	line-numbers-minus-style = "#E59A9A"
	line-numbers-plus-style = "#A8CBA0"
	line-numbers-zero-style = "#6e6e6e"

[merge]
	conflictstyle = diff3

[alias]
	# Status & Info
	st = status
	s = status --short
	
	# Branch
	br = branch
	bra = branch -a
	
	# Checkout
	co = checkout
	cob = checkout -b
	
	# Commit
	ci = commit
	cm = commit -m
	ca = commit --amend
	can = commit --amend --no-edit
	
	# Add
	a = add
	aa = add --all
	ap = add --patch
	
	# Diff
	d = diff
	ds = diff --staged
	dw = diff --word-diff
	
	# Log
	l = log --oneline --graph --decorate
	lg = log --oneline --graph --all --decorate
	last = log -1 HEAD
	who = shortlog -sn --
	
	# Stash
	ss = stash save
	sp = stash pop
	sl = stash list
	
	# Undo
	undo = reset --soft HEAD~1
	unstage = reset HEAD --
	discard = checkout --
	
	# Remote
	pl = pull
	ps = push
	psu = push -u origin HEAD
	f = fetch
	
	# Clean
	clean-branches = !git branch --merged | egrep -v '(^\\*|main|master|develop)' | xargs git branch -d

[color]
	ui = true

[color "diff"]
	meta = "#E3C58A"
	frag = "#8FB4E3"
	old = "#E59A9A"
	new = "#A8CBA0"

[color "status"]
	added = "#A8CBA0"
	changed = "#E3C58A"
	untracked = "#CBAACB"

[color "branch"]
	current = "#8FB4E3"
	local = "#c6c6c6"
	remote = "#A8CBA0"
