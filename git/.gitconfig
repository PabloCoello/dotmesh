[user]
	name = PabloCoello
	email = pablocoello@beway.com

[core]
	editor = nvim
	pager = delta
	autocrlf = input

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	default = simple
	autoSetupRemote = true

[fetch]
	prune = true

[diff]
	colorMoved = default

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	light = false
	side-by-side = true
	line-numbers = true
	syntax-theme = Pandora
	
	# Pandora theme colors
	minus-style = "syntax #E27056"
	minus-emph-style = "syntax #FF8A73"
	plus-style = "syntax #58B69D"
	plus-emph-style = "syntax #6FCDBA"
	hunk-header-style = "file line-number syntax #4F80DD"
	
	# Line numbers
	line-numbers-minus-style = "#E27056"
	line-numbers-plus-style = "#58B69D"
	line-numbers-zero-style = "#7F8182"

[merge]
	conflictstyle = diff3

[alias]
	# Status & Info
	st = status
	s = status --short
	
	# Branch
	br = branch
	bra = branch -a
	
	# Checkout
	co = checkout
	cob = checkout -b
	
	# Commit
	ci = commit
	cm = commit -m
	ca = commit --amend
	can = commit --amend --no-edit
	
	# Add
	a = add
	aa = add --all
	ap = add --patch
	
	# Diff
	d = diff
	ds = diff --staged
	dw = diff --word-diff
	
	# Log
	l = log --oneline --graph --decorate
	lg = log --oneline --graph --all --decorate
	last = log -1 HEAD
	who = shortlog -sn --
	
	# Stash
	ss = stash save
	sp = stash pop
	sl = stash list
	
	# Undo
	undo = reset --soft HEAD~1
	unstage = reset HEAD --
	discard = checkout --
	
	# Remote
	pl = pull
	ps = push
	psu = push -u origin HEAD
	f = fetch
	
	# Clean
	clean-branches = !git branch --merged | egrep -v '(^\\*|main|master|develop)' | xargs git branch -d

[color]
	ui = true

[color "diff"]
	meta = "#E5B15D"
	frag = "#4F80DD"
	old = "#E27056"
	new = "#58B69D"

[color "status"]
	added = "#58B69D"
	changed = "#E5B15D"
	untracked = "#CBAACB"

[color "branch"]
	current = "#4F80DD"
	local = "#D1D3D4"
	remote = "#58B69D"
