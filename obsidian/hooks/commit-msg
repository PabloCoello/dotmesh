#!/usr/bin/env bash
# Enforce commit tag format for the Pandora vault.
# Allowed tags: [diary] [meeting] [idea] [task] [study] [configuration]
# Usage: drop this file into .git/hooks/commit-msg inside the vault repo.

set -euo pipefail

commit_msg_file="$1"
message="$(cat "$commit_msg_file")"

# Allow merge/revert commits to pass
if [[ "$message" =~ ^Merge ]]; then
  exit 0
fi
if [[ "$message" =~ ^Revert ]]; then
  exit 0
fi

if [[ ! "$message" =~ ^\[(diary|meeting|idea|task|study|configuration)\]\  ]]; then
  cat <<'EOF'
Commit message must start with one of:
  [diary] [meeting] [idea] [task] [study] [configuration]
Example: [diary] Added entry for 2025-01-01
EOF
  exit 1
fi

exit 0
